{
  "defaultSeverity": "error",
  "extends": ["tslint:recommended"],
  "jsRules": {},
  "rules": {
    "variable-name": [
      true,
      "ban-keywords",
      "check-format",
      "allow-leading-underscore"
    ],
    "quotemark": false,
    "trailing-comma": false,
    "arrow-parens": false
  },
  "rulesDirectory": ["./_src", "__tests__"]
}
